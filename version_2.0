<!doctype html>
<html lang="ko">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>ES Dash-MATE Google Search Volume Dashboard - KO/EN Combined</title>
<style>
:root {
  --bg: #f4f5f7;
  --surface: #ffffff;
  --surface-soft: #fafafa;
  --ink: #15171c;
  --muted: #6b7280;
  --muted-2: #9ca3af;
  --line: #e5e7eb;
  --line-strong: #d1d5db;
  --brand: #a50034;
  --brand-2: #65001f;
  --brand-soft: #fff1f5;
  --sidebar: #151820;
  --sidebar-2: #25131a;
  --good: #2563eb;
  --bad: #dc2626;
  --neutral: #64748b;
  --shadow: 0 24px 70px rgba(15, 23, 42, .12);
  --radius-xl: 28px;
  --radius-lg: 20px;
  --radius-md: 14px;
}
* { box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  margin: 0;
  background:
    radial-gradient(circle at top right, rgba(165, 0, 52, .13), transparent 34rem),
    linear-gradient(180deg, #fbfbfc 0%, var(--bg) 52%, #eef0f3 100%);
  color: var(--ink);
  font-family: "Inter", "Pretendard", "Apple SD Gothic Neo", "Malgun Gothic", Arial, sans-serif;
  letter-spacing: -.01em;
}
a { color: inherit; text-decoration: none; }
.app-shell {
  display: grid;
  grid-template-columns: 292px minmax(0, 1fr);
  min-height: 100vh;
}
.sidebar {
  position: sticky;
  top: 0;
  height: 100vh;
  padding: 28px 22px;
  background: #A50034;
  color: #fff;
  overflow: auto;
  border-right: 1px solid rgba(255,255,255,.12);
}
.logo-row {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 34px;
}
.logo-mark {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  display: grid;
  place-items: center;
  font-weight: 800;
  background: #fff;
  color: var(--brand);
  box-shadow: 0 10px 30px rgba(0, 0, 0, .24);
}
.logo-text { font-weight: 800; font-size: 18px; letter-spacing: .01em; }
.side-kicker {
  color: rgba(255,255,255,.55);
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: .12em;
  margin: 26px 0 10px;
}
.side-title {
  font-size: 28px;
  line-height: 1.04;
  font-weight: 780;
  letter-spacing: -.05em;
  margin: 0 0 10px;
}
.period-pill {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  border: 1px solid rgba(255,255,255,.16);
  color: rgba(255,255,255,.84);
  background: rgba(255,255,255,.07);
  padding: 8px 12px;
  border-radius: 999px;
  font-size: 12px;
  margin: 10px 0 20px;
}
.side-nav { display: grid; gap: 8px; margin-bottom: 10px; }
.nav-pill, .lang-pill {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  border: 1px solid rgba(255,255,255,.15);
  background: rgba(255,255,255,.06);
  color: rgba(255,255,255,.78);
  border-radius: 16px;
  padding: 11px 12px;
  cursor: pointer;
  font: inherit;
  text-align: left;
  transition: .2s ease;
}
.nav-pill:hover, .lang-pill:hover, .nav-pill.is-active, .lang-pill.is-active {
  background: rgba(255,255,255,.14);
  color: #fff;
  transform: translateY(-1px);
}
.nav-pill.is-active::after, .lang-pill.is-active::after {
  content: "";
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 0 0 5px rgba(255,255,255,.12);
}
.internal-card {
  margin-top: 28px;
  border-radius: 20px;
  padding: 16px;
  background: rgba(255,255,255,.09);
  border: 1px solid rgba(255,255,255,.14);
  color: rgba(255,255,255,.76);
  font-size: 12px;
  line-height: 1.45;
}
.internal-card strong { display: block; color: #fff; font-size: 13px; margin-bottom: 3px; }
.content {
  min-width: 0;
  padding: 34px 38px 60px;
}
.content-inner {
  max-width: 1280px;
  margin: 0 auto;
}
.hero{
    position:relative;
    overflow:hidden;
    padding:48px;
    border-radius:28px;
    background:#A50034;      /* LG Red */
    color:#fff;
    box-shadow:0 12px 30px rgba(165,0,52,.18);
    margin-bottom:32px;
}

/* 기존 동그라미 제거 */
.hero::before{
    display:none;
}

/* 기존 효과 제거 */
.hero::after{
    display:none;
}

.hero-top{
    display:flex;
    justify-content:space-between;
    align-items:flex-start;
    margin-bottom:36px;
}

.hero h1{
    font-size:54px;
    font-weight:800;
    line-height:1.05;
    margin:18px 0;
    color:#fff;
}

.hero-sub{
    max-width:820px;
    color:rgba(255,255,255,.88);
    font-size:17px;
    line-height:1.7;
}

.hero-badge{
    display:inline-flex;
    align-items:center;
    padding:8px 14px;
    border-radius:999px;
    background:rgba(255,255,255,.15);
    border:1px solid rgba(255,255,255,.25);
    color:#fff;
    font-size:12px;
    font-weight:600;
}

.hero-meta{
    display:flex;
    gap:12px;
    flex-wrap:wrap;
    margin-top:28px;
}

.meta-chip{
    padding:10px 16px;
    border-radius:999px;
    background:#fff;
    color:#A50034;
    font-weight:700;
    border:none;
}
.mobile-switcher {
  display: none;
  gap: 10px;
  flex-wrap: wrap;
  margin: 0 0 22px;
}
.mobile-switcher .nav-pill, .mobile-switcher .lang-pill {
  width: auto;
  color: var(--ink);
  background: var(--surface);
  border-color: var(--line);
}
.mobile-switcher .is-active {
  color: var(--brand);
  background: var(--brand-soft);
  border-color: rgba(165,0,52,.22);
}
.lang-block, .product-panel { display: none; }
.lang-block.is-active, .product-panel.is-active { display: block; }
.product-header {
  display: grid;
  grid-template-columns: minmax(0,1fr) auto;
  gap: 20px;
  align-items: end;
  margin: 28px 0 18px;
}
.product-eyebrow {
  font-size: 12px;
  color: var(--brand);
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .12em;
  margin-bottom: 8px;
}
.product-title {
  margin: 0;
  font-size: clamp(24px, 3vw, 36px);
  letter-spacing: -.05em;
  line-height: 1.14;
}
.product-meta {
  color: var(--muted);
  font-size: 13px;
  padding-bottom: 5px;
  white-space: nowrap;
}
.section-card {
  background: rgba(255,255,255,.84);
  backdrop-filter: blur(14px);
  border: 1px solid rgba(229,231,235,.88);
  border-radius: var(--radius-xl);
  box-shadow: 0 16px 50px rgba(15,23,42,.08);
  overflow: hidden;
  margin: 20px 0 24px;
}
.section-head {
  padding: 22px 24px 18px;
  border-bottom: 1px solid var(--line);
  background:
    linear-gradient(90deg, rgba(165,0,52,.085), transparent 48%),
    rgba(255,255,255,.62);
}
.section-kicker {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  color: var(--brand);
  font-size: 11px;
  font-weight: 800;
  letter-spacing: .1em;
  text-transform: uppercase;
  margin-bottom: 8px;
}
.section-kicker::before {
  content: "";
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--brand);
}
.section-title {
  font-size: 21px;
  font-weight: 800;
  letter-spacing: -.035em;
}
.card-body { padding: 22px 24px 24px; }
.metric-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 14px;
}
.metric-card {
  min-height: 188px;
  border-radius: 22px;
  padding: 18px;
  background:
    linear-gradient(180deg, #fff 0%, #fbfbfc 100%);
  border: 1px solid var(--line);
  box-shadow: 0 10px 30px rgba(15,23,42,.06);
  display: flex;
  flex-direction: column;
}
.metric-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  margin-bottom: 18px;
}
.metric-label {
  font-size: 13px;
  font-weight: 800;
}
.metric-dim {
  font-size: 11px;
  color: var(--muted);
  border: 1px solid var(--line);
  padding: 5px 8px;
  border-radius: 999px;
  background: #fff;
}
.metric-value {
  font-size: 29px;
  line-height: 1.05;
  font-weight: 820;
  letter-spacing: -.045em;
  margin-bottom: 10px;
  overflow-wrap: anywhere;
}
.metric-yoy {
  width: fit-content;
  border-radius: 999px;
  padding: 6px 9px;
  font-weight: 800;
  font-size: 12px;
  margin-bottom: 14px;
  background: #eef2ff;
  color: var(--good);
}
.metric-yoy.down { background: #fef2f2; color: var(--bad); }
.metric-yoy.neutral { background: #f1f5f9; color: var(--neutral); }
.metric-comment {
  margin-top: auto;
  padding-top: 12px;
  border-top: 1px solid var(--line);
  color: #4b5563;
  font-size: 12.5px;
  line-height: 1.55;
}
.table-wrap {
  overflow: auto;
  border: 1px solid var(--line);
  border-radius: 20px;
  background: #fff;
}
table.report-table {
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
  min-width: 920px;
  font-size: 13px;
}
.report-table th {
  position: sticky;
  top: 0;
  z-index: 1;
  background: #191d26;
  color: #fff;
  padding: 12px 13px;
  text-align: left;
  font-weight: 780;
  border-right: 1px solid rgba(255,255,255,.12);
  white-space: nowrap;
}
.report-table th:last-child { border-right: 0; }
.report-table td {
  padding: 11px 13px;
  border-bottom: 1px solid var(--line);
  border-right: 1px solid #f1f2f4;
  vertical-align: top;
  background: rgba(255,255,255,.96);
}
.report-table tr:last-child td { border-bottom: 0; }
.report-table td:last-child { border-right: 0; }
.report-table tbody tr:hover td { background: #fff8fa; }
.report-table td.num { text-align: right; white-space: nowrap; font-variant-numeric: tabular-nums; }
.report-table td.label { font-weight: 760; color: #111827; white-space: nowrap; }
.report-table td.comment { min-width: 360px; color: #4b5563; line-height: 1.55; }
.report-table td.trend-up { color: var(--good); font-weight: 800; }
.report-table td.trend-down { color: var(--bad); font-weight: 800; }
.report-table td.trend-neutral { color: var(--neutral); }
.report-table tr.lg-row td {
  background: var(--brand-soft);
  color: #111827;
  font-weight: 780;
}
.report-table tr.lg-row:hover td { background: #ffe6ee; }
.report-table tr.group-start td { border-top: 2px solid var(--line-strong); }
.brand-cell {
  display: inline-flex;
  align-items: center;
  gap: 8px;
}
.brand-cell.lg::after {
  content: "LG";
  font-size: 10px;
  letter-spacing: .06em;
  color: #fff;
  background: var(--brand);
  border-radius: 999px;
  padding: 3px 6px;
}
.note-strip {
  margin-top: 14px;
  color: var(--muted);
  font-size: 12px;
  line-height: 1.55;
}
.footer {
  margin-top: 36px;
  color: var(--muted);
  font-size: 12px;
  text-align: center;
}
@media (max-width: 1120px) {
  .app-shell { grid-template-columns: 1fr; }
  .sidebar { display: none; }
  .content { padding: 22px 16px 46px; }
  .mobile-switcher { display: flex; }
  .metric-grid { grid-template-columns: repeat(2, minmax(0,1fr)); }
  .product-header { grid-template-columns: 1fr; }
  .product-meta { white-space: normal; }
}
@media (max-width: 700px) {
  .hero { padding: 26px 22px; border-radius: 22px; }
  .hero-top { flex-direction: column; margin-bottom: 28px; }
  .metric-grid { grid-template-columns: 1fr; }
  .section-head, .card-body { padding-left: 16px; padding-right: 16px; }
}
@media print {
  body { background: #fff; }
  .app-shell { display: block; }
  .sidebar, .mobile-switcher { display: none !important; }
  .content { padding: 0; }
  .hero, .section-card { box-shadow: none; break-inside: avoid; }
  .lang-block, .product-panel { display: block !important; }
  .report-table th { position: static; }
}


/* ===== Reference style override: header + left sidebar only ===== */
:root {
  --bg: #f0f2f5;
  --surface: #ffffff;
  --surface2: #f7f8fa;
  --border: #e8eaee;
  --accent: #c8102e;
  --accent-light: rgba(200,16,46,0.08);
  --text: #111827;
  --text-muted: #6b7280;
  --text-dim: #9ca3af;
}

body {
  background: var(--bg);
  color: var(--text);
}

.app-shell {
  grid-template-columns: 200px minmax(0, 1fr);
  min-height: 100vh;
}

.sidebar {
  position: sticky;
  top: 0;
  height: 100vh;
  width: 200px;
  padding: 0;
  background: #fff;
  color: var(--text);
  border-right: 1px solid var(--border);
  box-shadow: 2px 0 16px rgba(0,0,0,0.07);
  overflow: auto;
}

.logo-row {
  display: block;
  padding: 28px 22px 8px;
  margin: 0;
  border-bottom: 0;
}

.logo-mark {
  width: auto;
  height: auto;
  display: inline-block;
  border-radius: 4px;
  padding: 3px 8px;
  background: var(--accent);
  color: #fff;
  box-shadow: none;
  font-size: 9px;
  line-height: 1.4;
  font-weight: 800;
  letter-spacing: 1.5px;
}

.logo-text {
  margin-top: 8px;
  color: var(--text);
  font-size: 13px;
  font-weight: 800;
  line-height: 1.3;
  letter-spacing: -0.3px;
}

.side-title {
  padding: 0 22px 0;
  margin: 0;
  color: var(--text);
  font-size: 13px;
  font-weight: 800;
  line-height: 1.3;
  letter-spacing: -0.3px;
}

.side-title span {
  display: none !important;
}

.period-pill {
  display: block;
  width: fit-content;
  margin: 4px 22px 20px;
  padding: 0;
  border: 0;
  background: transparent;
  color: var(--text-dim);
  font-size: 9px;
  line-height: 1.5;
  letter-spacing: 0.5px;
}

.side-kicker {
  margin: 0;
  padding: 20px 22px 8px;
  border-top: 1px solid var(--border);
  color: var(--text-dim);
  font-size: 9px;
  font-weight: 800;
  letter-spacing: 2px;
  text-transform: uppercase;
}

.side-nav {
  display: grid;
  gap: 0;
  margin: 0 0 10px;
}

.nav-pill,
.lang-pill {
  position: relative;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 11px;
  border: 0;
  border-left: 3px solid transparent;
  border-radius: 0;
  background: transparent;
  color: var(--text-muted);
  padding: 13px 22px;
  font-size: 14px;
  font-weight: 700;
  line-height: 1.2;
  text-align: left;
  box-shadow: none;
  transform: none;
}

.nav-pill::before,
.lang-pill::before {
  content: "";
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--border);
  flex: 0 0 auto;
}

.nav-pill::after,
.lang-pill::after,
.nav-pill.is-active::after,
.lang-pill.is-active::after {
  display: none !important;
  content: none !important;
}

.nav-pill:hover,
.lang-pill:hover {
  background: var(--surface2);
  color: var(--text);
  transform: none;
}

.nav-pill.is-active,
.lang-pill.is-active {
  background: var(--accent-light);
  color: var(--accent);
  border-left-color: var(--accent);
  font-weight: 800;
  transform: none;
}

.nav-pill.is-active::before,
.lang-pill.is-active::before {
  background: var(--accent);
}

.side-kicker + .side-nav:last-of-type {
  padding: 0 22px 16px;
  gap: 6px;
}

.side-kicker + .side-nav:last-of-type .lang-pill {
  border: 1.5px solid var(--border);
  border-radius: 8px;
  padding: 10px 14px;
  font-size: 13px;
  font-weight: 700;
}

.side-kicker + .side-nav:last-of-type .lang-pill::before {
  width: 6px;
  height: 6px;
}

.side-kicker + .side-nav:last-of-type .lang-pill.is-active {
  background: var(--accent);
  border-color: var(--accent);
  color: #fff;
}

.side-kicker + .side-nav:last-of-type .lang-pill.is-active::before {
  background: rgba(255,255,255,0.55);
}

.content {
  padding: 24px 40px 60px;
}

.content-inner {
  max-width: 1200px;
}

.hero {
  position: relative;
  overflow: visible;
  padding: 36px 40px 28px;
  border-radius: 16px 16px 0 0;
  background: var(--accent);
  color: #fff;
  box-shadow: none;
  margin-bottom: 28px;
}

.hero::before,
.hero::after {
  display: none !important;
  content: none !important;
}

.hero-top {
  display: flex;
  justify-content: flex-end;
  align-items: flex-start;
  gap: 8px;
  margin: 0 0 10px;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 0;
  border: 0;
  background: rgba(255,255,255,0.15);
  color: rgba(255,255,255,0.85);
  border-radius: 20px;
  padding: 4px 12px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 1.2px;
  text-transform: uppercase;
}

.hero h1 {
  margin: 0 0 8px;
  max-width: none;
  color: #fff;
  font-size: clamp(18px, 2.8vw, 30px);
  font-weight: 900;
  line-height: 1.2;
  letter-spacing: -0.5px;
}

.hero-sub {
  max-width: none;
  margin: 0;
  color: rgba(255,255,255,0.75);
  font-size: 13px;
  line-height: 1.65;
}

.hero-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0;
  margin-top: 4px;
}

.meta-chip {
  padding: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  color: rgba(255,255,255,0.6);
  font-size: 12px;
  font-weight: 500;
}

.meta-chip + .meta-chip::before {
  content: "·";
  margin: 0 10px;
  color: rgba(255,255,255,0.55);
}

.mobile-switcher .nav-pill,
.mobile-switcher .lang-pill {
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 10px 12px;
  background: #fff;
  color: var(--text-muted);
}

.mobile-switcher .is-active {
  color: #fff;
  background: var(--accent);
  border-color: var(--accent);
}

@media (max-width: 1120px) {
  .app-shell { grid-template-columns: 1fr; }
  .sidebar { display: none; }
  .content { padding: 16px 16px 46px; }
  .mobile-switcher { display: flex; }
}

@media (max-width: 700px) {
  .hero { padding: 28px 24px; border-radius: 16px 16px 0 0; }
  .hero-top { justify-content: flex-start; flex-wrap: wrap; }
}

</style>

<style>
.lang-pill[role="button"] { cursor: pointer; }
.switch-group-title { color: rgba(255,255,255,.55); font-size: 11px; text-transform: uppercase; letter-spacing: .12em; margin: 26px 0 10px; }
.mobile-switcher .lang-pill[role="button"], .mobile-switcher .nav-pill { width: auto; }
</style>

</head>
<body>
  <main class="app-shell">
    <aside class="sidebar">
      <div class="logo-row"><div class="logo-mark">LGE</div><div class="logo-text"></div>
      <h2 class="side-title">Google Search Volume Report<br><span style="font-size:18px;opacity:.7;letter-spacing:-.03em;">Search Volume Dashboard</span></h2>
      <div class="period-pill">2026.01-05</div>
      <div class="side-kicker">Product</div>
      <nav class="side-nav">
        <button class="nav-pill is-active" data-product="ac" type="button">에어컨 / RAC</button>
        <button class="nav-pill" data-product="ap" type="button">공청기 / Air Purifier</button>
      </nav>
      <div class="side-kicker">Language</div>
      <nav class="side-nav">
        <button class="lang-pill is-active" data-lang="ko" type="button" role="button">한국어</button>
        <button class="lang-pill" data-lang="en" type="button" role="button">English</button>
      </nav>
    </aside>
    <section class="content"><div class="content-inner">
      <div class="mobile-switcher">
        <button class="nav-pill is-active" data-product="ac" type="button">에어컨 / RAC</button>
        <button class="nav-pill" data-product="ap" type="button">공청기 / Air Purifier</button>
        <button class="lang-pill is-active" data-lang="ko" type="button" role="button">한국어</button>
        <button class="lang-pill" data-lang="en" type="button" role="button">English</button>
      </div>
      <div class="lang-block is-active" data-lang="ko">

<section class="hero">
<div class="hero-top">
