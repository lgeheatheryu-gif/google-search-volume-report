<script>
(function () {
  function currentLang() {
    var active = document.querySelector('.lang-block.is-active');
    return active ? active.dataset.lang : 'ko';
  }
  function currentProduct(lang) {
    var block = document.querySelector('.lang-block[data-lang="' + lang + '"]');
    var active = block ? block.querySelector('.product-panel.is-active') : null;
    return active ? active.dataset.product : 'ac';
  }
  function syncButtons(lang, product) {
    document.querySelectorAll('.lang-pill[data-lang]').forEach(function (btn) {
      btn.classList.toggle('is-active', btn.dataset.lang === lang);
    });
    document.querySelectorAll('.nav-pill[data-product]').forEach(function (btn) {
      btn.classList.toggle('is-active', btn.dataset.product === product);
    });
  }
  function showLanguage(lang) {
    var product = currentProduct(lang) || 'ac';
    document.querySelectorAll('.lang-block').forEach(function (block) {
      block.classList.toggle('is-active', block.dataset.lang === lang);
    });
    showProduct(product, false);
    syncButtons(lang, product);
    document.documentElement.lang = lang;
  }
  function showProduct(product, syncOnly) {
    var lang = currentLang();
    var block = document.querySelector('.lang-block[data-lang="' + lang + '"]');
    if (!block) return;
    block.querySelectorAll('.product-panel').forEach(function (panel) {
      panel.classList.toggle('is-active', panel.dataset.product === product);
    });
    if (!syncOnly) syncButtons(lang, product);
  }
  document.addEventListener('click', function (event) {
    var langBtn = event.target.closest('.lang-pill[data-lang]');
    if (langBtn) {
      event.preventDefault();
      showLanguage(langBtn.dataset.lang);
      return;
    }
    var productBtn = event.target.closest('.nav-pill[data-product]');
    if (productBtn) {
      event.preventDefault();
      showProduct(productBtn.dataset.product, false);
    }
  });
  showLanguage('ko');
})();
</script>

</body>
</html>
